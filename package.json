{
  "name": "medcases-root",
  "version": "1.0.0",
  "description": "A teaching tool for creating and presenting medical cases classroom quizzes",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
